{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://happykhan.github.io/seebot/schemas/rankings.schema.json",
  "title": "Seebot award ranking view",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "rubric_version", "title", "scope_note", "provisional", "rankings"],
  "properties": {
    "schema_version": {"const": 1},
    "rubric_version": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "scope_note": {"type": "string", "minLength": 1},
    "provisional": {"type": "boolean"},
    "rankings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["package_id", "name", "version", "build", "subdir", "category", "description", "upstream_url", "run_id", "languages", "score", "maximum_points", "eligible", "missing_checks", "tier", "tier_colour", "breakdown", "rank"],
        "properties": {
          "package_id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "version": {"type": "string", "minLength": 1},
          "build": {"type": "string", "minLength": 1},
          "subdir": {"type": "string", "minLength": 1},
          "category": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "upstream_url": {"type": "string", "format": "uri"},
          "run_id": {"type": "string", "minLength": 1},
          "languages": {"type": "array", "items": {"enum": ["python", "perl", "c", "cpp", "rust", "cython"]}, "uniqueItems": true},
          "score": {"type": "number", "minimum": 0, "maximum": 100},
          "maximum_points": {"const": 100},
          "eligible": {"type": "boolean"},
          "missing_checks": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "tier": {"enum": ["Gold", "Silver", "Bronze", "Reviewed"]},
          "tier_colour": {"type": "string", "pattern": "^#[0-9a-fA-F]{6}$"},
          "breakdown": {
            "type": "object",
            "additionalProperties": false,
            "required": ["testing", "automation", "documentation", "stewardship", "reproducibility"],
            "properties": {
              "testing": {"type": "number", "minimum": 0, "maximum": 25},
              "automation": {"type": "number", "minimum": 0, "maximum": 20},
              "documentation": {"type": "number", "minimum": 0, "maximum": 20},
              "stewardship": {"type": "number", "minimum": 0, "maximum": 20},
              "reproducibility": {"type": "number", "minimum": 0, "maximum": 15}
            }
          },
          "rank": {"type": ["integer", "null"], "minimum": 1}
        }
      }
    }
  }
}
