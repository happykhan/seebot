{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://happykhan.github.io/seebot/schemas/check-result.schema.json",
  "title": "Seebot individual check result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "project_id", "repository_id", "snapshot_date", "snapshot_commit", "source_component_id", "executable_id", "installation_id", "check_id", "probe_id", "domain", "status", "result_kind", "applicability", "method", "expected", "observed", "tool", "command", "started_at", "duration_seconds", "environment_id", "config_sha256", "evidence", "notes"],
  "properties": {
    "schema_version": {"const": 2},
    "run_id": {"type": "string", "minLength": 1},
    "project_id": {"type": "string", "minLength": 1},
    "repository_id": {"type": ["string", "null"]},
    "snapshot_date": {"type": "string", "format": "date"},
    "snapshot_commit": {"type": ["string", "null"]},
    "source_component_id": {"type": ["string", "null"]},
    "executable_id": {"type": ["string", "null"]},
    "installation_id": {"type": ["string", "null"]},
    "check_id": {"type": "string", "pattern": "^[A-Z]+(?:-[A-Z0-9]+)+-[0-9]{3}$"},
    "probe_id": {"type": "string", "minLength": 1},
    "domain": {"enum": ["cohort", "repository", "source", "dependencies", "usage", "robustness", "manual"]},
    "status": {"enum": ["PASS", "FAIL", "OBSERVED", "NOT_OBSERVED", "NOT_APPLICABLE", "UNTESTABLE", "ERROR", "NOT_RUN", "NOT_EXISTING"]},
    "result_kind": {"enum": ["CONTRACT", "MEASUREMENT"]},
    "applicability": {"enum": ["APPLICABLE", "NOT_APPLICABLE", "UNKNOWN"]},
    "method": {"enum": ["automated", "automated_with_manifest", "manual", "agent", "adjudicated"]},
    "expected": {"type": "object"},
    "observed": {"type": "object"},
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {"name": {"type": "string"}, "version": {"type": "string"}}
    },
    "command": {"type": ["array", "null"], "items": {"type": "string"}},
    "started_at": {"type": "string", "format": "date-time"},
    "duration_seconds": {"type": "number", "minimum": 0},
    "environment_id": {"type": "string", "minLength": 1},
    "config_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stdout", "stderr", "metadata"],
      "properties": {"stdout": {"type": "string"}, "stderr": {"type": "string"}, "metadata": {"type": "string"}}
    },
    "notes": {"type": ["string", "null"]}
  }
}
